# Environment Configuration Example

# Copy this file as .env.local and fill in your values

# Backend Configuration
# For production, use your deployed API URL
# For local development, leave empty and use LOCAL_IP in src/config/api.ts
EXPO_PUBLIC_DEPLOYED_API_URL=

# For local development, this is configured in src/config/api.ts
# Android Emulator will use: http://10.0.2.2:5000/api
# iOS Simulator will use: http://localhost:5000/api
# Real Device will use: http://<LOCAL_IP>:5000/api

# Debug Mode (show API logs)
DEBUG=true
